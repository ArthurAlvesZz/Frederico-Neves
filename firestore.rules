rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrappedAdmin() {
      // The user runtime email mapped as Supreme Admin
      return isSignedIn() && request.auth.token.email == "arthurfgalves@gmail.com";
    }

    function isAdmin() {
      // Allow if supreme admin, or if their uid is explicitly in the /admins collection
      return isBootstrappedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Property Validation Guard
    function isValidProperty(data) {
      return 
        data.keys().hasOnly(['id', 'title', 'desc', 'price', 'location', 'neighborhood', 'beds', 'baths', 'sqft', 'garage', 'tipo', 'tag', 'image', 'images', 'videoUrl', 'isUnlisted', 'createdAt', 'updatedAt']) &&
        data.title is string && data.title.size() <= 200 &&
        data.desc is string && data.desc.size() <= 10000 &&
        data.price is number && data.price >= 0 &&
        data.location is string && data.location.size() <= 100 &&
        data.neighborhood is string && data.neighborhood.size() <= 100 &&
        data.createdAt is number && 
        data.updatedAt is number &&
        (data.get('beds', 0) is number) &&
        (data.get('baths', 0) is number) &&
        (data.get('sqft', 0) is number) &&
        (data.get('garage', 0) is number) &&
        (data.get('tipo', '') is string) &&
        (data.get('tag', '') is string) &&
        (data.get('image', '') is string) &&
        (data.get('images', []) is list) &&
        (data.get('videoUrl', '') is string) &&
        (data.get('isUnlisted', false) is bool);
    }

    // Admin Validation Guard
    function isValidAdmin(data) {
      return
        data.keys().hasAll(['email', 'createdAt']) &&
        data.keys().size() == 2 &&
        data.email is string && data.email.size() <= 256 &&
        data.createdAt is number;
    }

    match /admins/{userId} {
      allow read: if isAdmin();
      allow create: if isBootstrappedAdmin() && isValidId(userId) && isValidAdmin(incoming());
      allow delete: if isBootstrappedAdmin();
    }

    match /properties/{propertyId} {
      allow get: if isValidId(propertyId);
      
      // Prevent query scraping of unlisted properties.
      allow list: if isAdmin() || (resource.data.get('isUnlisted', false) == false);
      
      // Admins manage properties
      allow create: if isAdmin() && isValidId(propertyId) && isValidProperty(incoming());
      
      allow update: if isAdmin() && isValidProperty(incoming()) && incoming().createdAt == existing().createdAt;
      
      allow delete: if isAdmin();
    }
  }
}
